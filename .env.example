# API-FOOTBALL / API-Sports key
# Get a free key at https://www.api-football.com/ or https://dashboard.api-football.com/
# Without a key the app falls back to mock data automatically.
API_FOOTBALL_KEY=

# Optional: override the API base host.
# api-football.com direct: https://v3.football.api-sports.io
# RapidAPI variant:        https://api-football-v1.p.rapidapi.com/v3
API_FOOTBALL_HOST=https://v3.football.api-sports.io

# ─────────────────────────────────────────────────────────────
# ONLINE FAN CHAT (optional). When all values below are present the
# chat runs online: shared, persisted, realtime and authenticated.
# Leave empty to keep the offline localStorage chat.
# ─────────────────────────────────────────────────────────────

# 1) Neon Postgres — stores chat messages.
#    Create at https://neon.tech (or `vercel integration add neon`).
DATABASE_URL=

# 2) Clerk — user accounts (email + Google), profile, avatar.
#    Create at https://clerk.com (or `vercel integration add clerk`).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# 3) Pusher Channels — realtime message delivery.
#    Create a free app at https://pusher.com/channels
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ─────────────────────────────────────────────────────────────
# SHABBAT GUARD — blocks interactive features during Shabbat
# Uses Hebcal API (https://www.hebcal.com) + IP geolocation (ipapi.co)
# Based on https://github.com/liad07/shabbat-guard
# ─────────────────────────────────────────────────────────────

# Set to "false" to disable Shabbat protection entirely
NEXT_PUBLIC_SHABBAT_GUARD_ENABLED=true

# Location: api | none
# api = IP geolocation via ipapi.co, falls back to Jerusalem/Israel default
NEXT_PUBLIC_SHABBAT_LOCATION=api

# Minhag: default (40min) | chabad (50min) | jerusalem40 | custom
NEXT_PUBLIC_SHABBAT_MINHAG=default

# Custom havdalah minutes (only when MINHAG=custom)
NEXT_PUBLIC_SHABBAT_HAVDALAH_MINUTES=40

# Pre-Shabbat warning banner minutes before candle lighting
NEXT_PUBLIC_SHABBAT_WARNING_MINUTES=60

# Locale for time formatting
NEXT_PUBLIC_SHABBAT_LOCALE=he-IL
